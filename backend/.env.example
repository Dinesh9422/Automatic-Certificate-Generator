# ─── CertifyAI Backend .env ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=django-insecure-replace-this-with-a-strong-secret-key-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Neon PostgreSQL (cloud) or local PostgreSQL
DATABASE_URL=postgresql://username:password@host/database_name
# For local dev: DATABASE_URL=postgresql://postgres:password@localhost:5432/certifyai_db

# JWT
JWT_EXPIRY_HOURS=24

# CORS — Frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Tesseract OCR path
# Linux/Mac: /usr/bin/tesseract
# Windows:   C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract
